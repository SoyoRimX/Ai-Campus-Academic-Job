<view class="page index-page">
  <!-- 欢迎区 -->
  <view class="welcome-area">
    <view class="welcome-greeting">{{greeting}}</view>
    <view class="welcome-sub">AI 校园学业就业助手，陪伴你的大学生涯</view>
  </view>

  <!-- 快捷入口 -->
  <view class="entry-grid">
    <view class="entry-card tappable" wx:for="{{entries}}" wx:key="key" bindtap="goPage" data-url="{{item.url}}">
      <view class="entry-icon-box" style="background:{{item.bg}}">{{item.icon}}</view>
      <text class="entry-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 推荐岗位 -->
  <view class="section">
    <view class="section-hd">
      <text class="section-title">推荐岗位</text>
      <text class="text-sm text-muted tappable" bindtap="goPage" data-url="/pages/jobs-tab/jobs-tab">查看全部 ›</text>
    </view>
    <view class="card" wx:if="{{jobs.length}}">
      <view class="list-item tappable" wx:for="{{jobs}}" wx:key="id" bindtap="goPage" data-url="/pages/jobs/detail?id={{item.id}}">
        <view class="flex-1">
          <view class="text-base font-medium text-ellipsis">{{item.title || item.jobTitle}}</view>
          <view class="text-sm text-muted" style="margin-top:4px">{{item.company || item.companyName}} · {{item.location || item.city}}</view>
        </view>
        <view class="text-base font-semibold" style="color:var(--color-primary-dark);white-space:nowrap">{{item.salary || '面议'}}</view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <view class="empty-state-icon">📭</view>
      <view class="empty-state-text">暂无推荐岗位</view>
    </view>
  </view>

  <!-- 最新预警 -->
  <view class="section">
    <view class="section-hd">
      <text class="section-title">学业预警</text>
      <text class="text-sm text-muted tappable" bindtap="goPage" data-url="/pages/study/study">查看全部 ›</text>
    </view>
    <view class="card" wx:if="{{warnings.length}}">
      <view class="list-item tappable" wx:for="{{warnings}}" wx:key="id">
        <view class="dot" style="background:{{item.level === 3 ? 'var(--color-danger)' : item.level === 2 ? '#F97316' : 'var(--color-warning)'}}"></view>
        <view class="flex-1" style="margin-left:var(--space-3)">
          <view class="text-sm font-medium text-ellipsis">{{item.title}}</view>
          <view class="text-xs text-muted" style="margin-top:2px">{{item.studentName}} · {{item.studentNo}}</view>
        </view>
        <text class="text-xs text-muted">{{item.time}}</text>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <view class="empty-state-icon">✅</view>
      <view class="empty-state-text">暂无预警，一切正常</view>
    </view>
  </view>
</view>
