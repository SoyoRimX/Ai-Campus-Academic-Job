.index-page { padding-top: var(--space-6); }

/* ---- Welcome ---- */
.welcome-area { padding: 0 var(--space-1); margin-bottom: var(--space-6); }
.welcome-greeting { font-size: var(--font-2xl); font-weight: var(--font-weight-bold); color: var(--color-text); }
.welcome-sub { font-size: var(--font-sm); color: var(--color-text-secondary); margin-top: var(--space-1); }

/* ---- Entry Grid ---- */
.entry-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3);
  margin-bottom: var(--space-6);
}
.entry-card {
  display: flex; flex-direction: column; align-items: center; gap: var(--space-2);
  padding: var(--space-4) var(--space-2);
  background: var(--color-surface); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.entry-icon-box {
  width: 48px; height: 48px; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 24px;
}
.entry-label { font-size: var(--font-xs); color: var(--color-text-secondary); font-weight: var(--font-weight-medium); }

/* ---- Section ---- */
.section { margin-bottom: var(--space-6); }
