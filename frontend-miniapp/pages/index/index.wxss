/*
 * ============================================
 *  AI校园学业就业助手 — 首页样式
 *  盐系极简 · 毛玻璃 frost · backdrop-filter
 * ============================================
 */

/* ===== 页面容器 ===== */
.index-page {
  position: relative;
  min-height: 100vh;
  background-color: #F8F9FA;
  z-index: 1;
}

/* 页面背景装饰（为毛玻璃提供下层模糊源） */
.page-bg-deco {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at 20% 10%, rgba(157, 180, 192, 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 70%, rgba(201, 214, 223, 0.10) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* ===========================================
   1. 顶部横向滑动公告栏 — 毛玻璃效果
      + 自定义指示点（大小+亮度变化）
   =========================================== */
.notice-bar-wrap {
  margin: 12px 16px 6px;
  border-radius: 12px;
  overflow: hidden;
}

.notice-swiper {
  height: 44px;
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-radius: 12px;
  border: 1px solid rgba(157, 180, 192, 0.18);
}

.notice-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 20px;
}

.notice-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}

.notice-text {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  letter-spacing: 1px;
}

/* ---- 自定义指示点容器 ---- */
.notice-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-top: 8px;
  padding: 4px 0;
}

/* ---- 单个指示点（默认/非激活态） ---- */
.notice-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #D1D5DB;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ---- 当前激活态：尺寸变大 + 亮度增强 + 颜色切换 ---- */
.notice-dot-active {
  width: 10px;
  height: 10px;
  background-color: #9DB4C0;
  box-shadow: 0 0 6px rgba(157, 180, 192, 0.5);
}

/* ===========================================
   2. 功能入口区 — 4个静态卡片一行排列
      无需滑动，圆角+浅背景
   =========================================== */
.entry-section {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 10px;
  padding: 0 16px;
  margin-bottom: 20px;
}

.entry-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 6px;
  border-radius: 12px;
  background-color: #FFFFFF;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.entry-hover {
  transform: scale(1.04);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
}

.entry-icon-wrap {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
  background-color: #ECF3F6;
}

.entry-icon {
  font-size: 22px;
}

.entry-label {
  font-size: 12px;
  color: #666666;
  font-weight: 500;
}

/* ===========================================
   3. 公用区块
   =========================================== */
.section {
  padding: 0 16px;
  margin-bottom: 20px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}

.section-title-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: #9DB4C0;
}

.section-dot-warn {
  background-color: #C9D6DF;
}

.section-title-text {
  font-size: 16px;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 12px;
  color: #9DB4C0;
}

/* ===========================================
   毛玻璃卡片（推荐岗位 / 最新预警）
   backdrop-filter 半透明磨砂
   兼容微信小程序真机
   =========================================== */
.frost-card {
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(157, 180, 192, 0.12);
  overflow: hidden;
}

/* ===========================================
   推荐岗位列表
   每行前添加公文包图标
   =========================================== */
.job-list {
}

.job-item {
  display: flex;
  align-items: center;
  padding: 14px 14px;
  border-bottom: 1px solid rgba(224, 229, 233, 0.5);
  gap: 10px;
}

.job-item:last-child {
  border-bottom: none;
}

.job-hover {
  background-color: rgba(157, 180, 192, 0.06);
}

/* 公文包图标 */
.job-briefcase {
  font-size: 20px;
  flex-shrink: 0;
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ECF3F6;
  border-radius: 8px;
}

.job-item-left {
  flex: 1;
  overflow: hidden;
}

.job-item-name {
  font-size: 14px;
  color: #333333;
  font-weight: 500;
  margin-bottom: 3px;
}

.job-item-company {
  font-size: 12px;
  color: #999999;
}

.job-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  flex-shrink: 0;
}

.job-item-salary {
  font-size: 14px;
  color: #C59B9B;
  font-weight: 600;
  white-space: nowrap;
}

.job-item-date {
  font-size: 11px;
  color: #D1D5DB;
}

/* ===========================================
   最新预警列表（毛玻璃）
   =========================================== */
.announce-list {
}

.announce-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 16px;
  border-bottom: 1px solid rgba(224, 229, 233, 0.5);
}

.announce-item:last-child {
  border-bottom: none;
}

.announce-hover {
  background-color: rgba(157, 180, 192, 0.06);
}

.announce-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 10px;
}

.announce-bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #C9D6DF;
  flex-shrink: 0;
  margin-right: 8px;
}

.announce-title {
  font-size: 14px;
  color: #333333;
  flex: 1;
}

.announce-date {
  font-size: 12px;
  color: #999999;
  white-space: nowrap;
  flex-shrink: 0;
}
