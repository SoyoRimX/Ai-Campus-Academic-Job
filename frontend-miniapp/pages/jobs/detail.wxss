.container {
  padding: 20rpx;
  padding-bottom: 130rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* Detail header */
.detail-header {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 16rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
}
.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}
.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.detail-company {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}
.detail-salary {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFD700;
}

/* Card base */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* Info rows */
.info-card .info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-card .info-item:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #888;
}
.info-val {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* Section title with left accent */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.title-bar {
  width: 6rpx;
  height: 32rpx;
  background-color: #4A90D9;
  border-radius: 3rpx;
  margin-right: 14rpx;
}
.section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* Skills */
.skills-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.skill-tag {
  font-size: 24rpx;
  color: #4A90D9;
  background-color: #EBF3FC;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

/* Description */
.desc-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}
.btn-apply {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}
.btn-apply text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
