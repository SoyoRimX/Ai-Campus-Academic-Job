.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* Search bar - fixed top */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 64rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.placeholder {
  color: #bbb;
}
.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ddd;
  border-radius: 50%;
}
.search-clear text {
  font-size: 24rpx;
  color: #fff;
  line-height: 1;
}
.search-btn {
  margin-left: 16rpx;
  padding: 0 28rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4A90D9;
  border-radius: 32rpx;
}
.search-btn text {
  font-size: 26rpx;
  color: #fff;
}

/* Job list */
.job-list {
  flex: 1;
  padding: 100rpx 24rpx 20rpx;
}

/* Job card */
.job-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.job-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.job-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 20rpx;
}
.job-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.job-company {
  font-size: 26rpx;
  color: #888;
}
.job-salary {
  font-size: 32rpx;
  font-weight: 700;
  color: #E74C3C;
  flex-shrink: 0;
}
.job-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.job-city {
  font-size: 24rpx;
  color: #888;
}
.job-tag {
  font-size: 22rpx;
  color: #4A90D9;
  background-color: #EBF3FC;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}
.job-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* Load more */
.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}
.load-more text {
  font-size: 24rpx;
  color: #bbb;
}

/* Empty */
.empty-result {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}
