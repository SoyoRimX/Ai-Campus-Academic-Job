<view class="page detail-page">
  <!-- 岗位头部 -->
  <view class="detail-header">
    <text class="detail-title">{{job.jobTitle || job.title || '岗位详情'}}</text>
    <view class="flex-between" style="margin-top:var(--space-2)">
      <text class="text-base" style="color:rgba(255,255,255,0.85)">{{job.company || job.companyName || '—'}}</text>
      <text class="text-lg font-bold" style="color:#FFE5A3">{{job.salary || job.salaryRange || '面议'}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card" style="padding:var(--space-4)">
    <view class="list-item" wx:if="{{job.city || job.location}}">
      <text class="text-sm text-muted">工作城市</text>
      <text class="text-sm font-medium">{{job.city || job.location}}</text>
    </view>
    <view class="list-item" wx:if="{{job.education}}">
      <text class="text-sm text-muted">学历要求</text>
      <text class="text-sm font-medium">{{job.education}}</text>
    </view>
    <view class="list-item" wx:if="{{job.experience}}">
      <text class="text-sm text-muted">经验要求</text>
      <text class="text-sm font-medium">{{job.experience}}</text>
    </view>
    <view class="list-item" wx:if="{{job.jobType}}">
      <text class="text-sm text-muted">工作类型</text>
      <text class="tag tag-primary">{{job.jobType}}</text>
    </view>
  </view>

  <!-- 技能要求 -->
  <view class="card" style="margin-top:var(--space-3);padding:var(--space-4)" wx:if="{{job.skills && job.skills.length}}">
    <text class="text-md font-semibold" style="margin-bottom:var(--space-3);display:block">技能要求</text>
    <view class="flex gap-2" style="flex-wrap:wrap">
      <text class="tag tag-primary" wx:for="{{job.skills}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 职位描述 -->
  <view class="card" style="margin-top:var(--space-3);padding:var(--space-4)">
    <text class="text-md font-semibold" style="margin-bottom:var(--space-3);display:block">职位描述</text>
    <text class="text-sm" style="color:var(--color-text-secondary);line-height:1.8;white-space:pre-wrap">{{job.description || '暂无详细描述'}}</text>
  </view>

  <!-- 底部投递 -->
  <view class="bottom-bar">
    <button class="btn-primary" style="width:100%" bindtap="onApply">立即投递</button>
  </view>
</view>
