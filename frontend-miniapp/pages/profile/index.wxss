.profile-page { padding-top: 0; }

/* ---- Unlogged ---- */
.unlogged {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  gap: var(--space-4);
}
.unlogged-avatar { font-size: 64px; opacity: 0.8; }
.unlogged-title { font-size: var(--font-lg); font-weight: var(--font-weight-semibold); color: var(--color-text); }
.unlogged-desc { font-size: var(--font-sm); color: var(--color-text-secondary); margin-bottom: var(--space-2); }

/* ---- User Card ---- */
.user-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: var(--space-4);
}
.user-card-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}
.user-card-body {
  position: relative; z-index: 1;
  display: flex; align-items: center; gap: var(--space-4);
  padding: var(--space-6);
}
.user-avatar {
  width: 64px; height: 64px; border-radius: var(--radius-full);
  background: rgba(255,255,255,0.25); color: #FFF;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-xl); font-weight: var(--font-weight-bold);
  flex-shrink: 0;
}
.user-name {
  font-size: var(--font-xl); font-weight: var(--font-weight-bold); color: #FFF; margin-bottom: 4px;
}
.user-meta { display: flex; gap: var(--space-3); }
.user-meta-item { font-size: var(--font-xs); color: rgba(255,255,255,0.8); }

/* ---- Stats Row ---- */
.stats-row {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-2);
  margin-bottom: var(--space-4);
}
.stat-item {
  background: var(--color-surface); border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-2); text-align: center;
  box-shadow: var(--shadow-sm);
}
.stat-num { font-size: var(--font-xl); font-weight: var(--font-weight-bold); color: var(--color-primary-dark); }
.stat-label { font-size: var(--font-xs); color: var(--color-text-secondary); margin-top: 2px; }

/* ---- Menu ---- */
.menu-card {
  background: var(--color-surface); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); overflow: hidden;
}
.menu-item {
  display: flex; align-items: center; padding: var(--space-4);
  border-bottom: 1px solid var(--color-border-light);
  gap: var(--space-3);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--color-bg); }

.menu-icon-box {
  width: 40px; height: 40px; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
}
.icon-resume { background: var(--color-primary-bg); }
.icon-interview { background: var(--color-danger-bg); }
.icon-warning { background: var(--color-warning-bg); }
.icon-jobs { background: var(--color-success-bg); }
.icon-contact { background: #EDEEF5; }

.menu-text { flex: 1; font-size: var(--font-base); font-weight: var(--font-weight-medium); color: var(--color-text); }
.menu-arrow { font-size: 22px; color: var(--color-text-muted); }

/* ---- Logout ---- */
.logout-wrap { padding: var(--space-6) 0; padding-bottom: calc(var(--safe-bottom) + var(--space-6)); }
