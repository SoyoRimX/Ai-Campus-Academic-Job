.jobs-tab-page { padding-top: 0; }

.search-bar { padding: var(--space-3) var(--space-4); background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
.search-input-wrap {
  display: flex; align-items: center; gap: var(--space-2);
  background: var(--color-bg); border-radius: var(--radius-full);
  padding: 0 var(--space-4); height: 40px;
}
.search-icon { font-size: 14px; opacity: 0.5; flex-shrink: 0; }
.search-input { flex: 1; font-size: var(--font-base); color: var(--color-text); }
.search-clear { font-size: 14px; color: var(--color-text-muted); padding: var(--space-1); }
.section { padding: 0 var(--space-4); margin-top: var(--space-3); }
.job-avatar {
  width: 44px; height: 44px; border-radius: var(--radius-md);
  background: var(--color-primary-bg);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.load-more { padding: var(--space-4); text-align: center; }
