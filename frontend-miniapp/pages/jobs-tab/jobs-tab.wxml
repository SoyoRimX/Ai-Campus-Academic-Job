<view class="page jobs-tab-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" placeholder="搜索岗位、公司或技能" confirm-type="search" />
      <text class="search-clear tappable" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 岗位列表 -->
  <view class="section" wx:if="{{jobs.length}}">
    <view class="section-hd">
      <text class="section-title">{{keyword ? '搜索结果' : '全部岗位'}}</text>
      <text class="text-xs text-muted">共 {{total}} 个</text>
    </view>

    <view class="card">
      <view class="list-item tappable" wx:for="{{jobs}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="job-avatar">💼</view>
        <view class="flex-1" style="margin-left:var(--space-3)">
          <view class="text-base font-semibold text-ellipsis">{{item.jobTitle || item.title || item.name}}</view>
          <view class="flex gap-2" style="margin-top:6px;flex-wrap:wrap">
            <text class="text-xs text-muted">{{item.company || item.companyName || '—'}}</text>
            <text class="text-xs text-muted" wx:if="{{item.city || item.location}}">· {{item.city || item.location}}</text>
            <view class="tag tag-primary" wx:if="{{item.jobType || item.type}}">{{item.jobType || item.type}}</view>
          </view>
        </view>
        <text class="text-md font-bold" style="color:var(--color-primary-dark);white-space:nowrap">{{item.salary || item.salaryRange || '面议'}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-state-icon">🔎</view>
    <view class="empty-state-text">{{keyword ? '未找到匹配岗位' : '暂无岗位信息'}}</view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text class="text-sm text-muted tappable" bindtap="loadMore">加载更多</text>
  </view>
</view>
