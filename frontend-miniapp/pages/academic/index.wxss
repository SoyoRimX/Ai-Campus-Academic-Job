/*
 * ============================================
 *  AI校园学业就业助手 — 学业页样式
 *  盐系极简设计风格
 * ============================================
 */

/* ===== 页面容器 ===== */
.academic-page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding: 24rpx 30rpx;
  padding-bottom: 20rpx;
}

/* ========================================
   用户信息卡片
   横向布局：左侧头像+信息，右侧圆形绩点
   ======================================== */
.student-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.student-card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

/* 头像占位圆 */
.student-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: #E0E5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.student-avatar-emoji {
  font-size: 40rpx;
  opacity: 0.6;
}

/* 姓名 + 专业信息 */
.student-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.student-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.student-major {
  font-size: 26rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========================================
   圆形绩点展示组件
   ======================================== */
.gpa-circle {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.gpa-circle-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.gpa-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #9DB4C0;
  line-height: 1.1;
}

.gpa-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 2rpx;
}

/* 绩点环形背景装饰 */
.gpa-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid #E0E5E9;
  box-sizing: border-box;
  z-index: 1;
}

/* 绩点环形进度（通过 border-image 或伪元素实现） */
.gpa-ring::after {
  content: '';
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: #9DB4C0;
  border-right-color: #9DB4C0;
  box-sizing: border-box;
  transform: rotate(-45deg);
  z-index: 3;
}

/* ========================================
   学分进度区
   ======================================== */
.credit-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.credit-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #666666;
}

.credit-num {
  font-size: 28rpx;
  color: #9DB4C0;
  font-weight: bold;
}

/* 进度条 */
.credit-card .progress-bar {
  height: 14rpx;
  background-color: #E0E5E9;
  border-radius: 7rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.credit-card .progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #9DB4C0 0%, #B8C5D6 100%);
  border-radius: 7rpx;
}

/* 进度条动画 */
.progress-bar-fill.animated {
  width: 0;
  transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

.credit-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.credit-hint {
  font-size: 24rpx;
  color: #999999;
}

.credit-percent {
  font-size: 24rpx;
  color: #9DB4C0;
  font-weight: bold;
}

/* ========================================
   状态模块：学业进度 + 不及格科目
   双卡片横向布局
   ======================================== */
.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.stat-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 图标容器 */
.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.progress-icon {
  background-color: #ECF3F6;
}

.fail-icon {
  background-color: #F5ECEC;
}

.stat-icon-emoji {
  font-size: 34rpx;
}

.stat-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.stat-data {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #666666;
  line-height: 1;
}

.stat-value.fail-value {
  color: #C59B9B;
}

.stat-unit {
  font-size: 24rpx;
  color: #999999;
}

.stat-desc {
  font-size: 22rpx;
  color: #999999;
}

.stat-desc.fail-desc {
  color: #C59B9B;
}

/* ========================================
   预警信息模块标题
   ======================================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #C59B9B;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #666666;
}

/* ========================================
   预警列表
   ======================================== */
.warning-list {
  margin-bottom: 24rpx;
}

.warning-item {
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
  transition: transform 0.2s ease;
}

.warning-item:active {
  transform: scale(0.99);
}

.warning-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.warning-title {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.warning-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.warning-time {
  font-size: 22rpx;
  color: #D1D5DB;
}
