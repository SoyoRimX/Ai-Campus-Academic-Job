<view class="page study-page">
  <!-- 学生信息卡片 -->
  <view class="student-card">
    <view class="sc-avatar">{{studentInfo.name ? studentInfo.name.charAt(0) : 'U'}}</view>
    <view class="flex-1" style="margin-left:var(--space-3);overflow:hidden">
      <view class="flex" style="align-items:baseline;gap:var(--space-2)">
        <text class="text-lg font-bold text-ellipsis">{{studentInfo.name || '未设置'}}</text>
        <text class="lv-badge tappable" bindtap="onLvTap">LV.{{lvLevel}} {{lvTitle}}</text>
      </view>
      <text class="text-sm text-muted" style="margin-top:2px">{{studentInfo.major || '—'}} · {{studentInfo.grade || '—'}}</text>
    </view>
    <view class="gpa-ring-mini">
      <canvas class="gpa-canvas" canvas-id="gpaCanvas" id="gpaCanvas"></canvas>
      <view class="gpa-center">
        <text class="gpa-value">{{studentInfo.gpa}}</text>
        <text class="gpa-unit">/4.0</text>
      </view>
    </view>
  </view>

  <!-- 学分明细 -->
  <view class="card" style="margin-bottom:var(--space-3);padding:var(--space-4)">
    <view class="flex-between" style="margin-bottom:var(--space-3)">
      <text class="text-md font-semibold">学分明细</text>
      <text class="text-base font-semibold" style="color:var(--color-primary-dark)">{{studentInfo.totalCredits}} / {{studentInfo.requiredCredits}}</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width:{{creditPercent}}%"></view>
    </view>
    <view class="flex-between" style="margin-top:var(--space-2)">
      <text class="text-xs text-muted">距毕业还需 {{remainingCredits}} 学分</text>
      <text class="text-xs font-semibold" style="color:var(--color-primary-dark)">{{creditPercent}}%</text>
    </view>
  </view>

  <!-- 统计双卡 -->
  <view class="flex gap-3" style="margin-bottom:var(--space-3)">
    <view class="stat-card flex-1">
      <text class="text-xs text-muted">学业进度</text>
      <text class="text-xl font-bold" style="margin-top:var(--space-1);color:var(--color-primary-dark)">{{creditPercent}}%</text>
      <text class="text-xs text-muted" style="margin-top:2px">{{studentInfo.totalCredits}} 学分已修</text>
    </view>
    <view class="stat-card flex-1">
      <text class="text-xs text-muted">不及格科目</text>
      <text class="text-xl font-bold" style="margin-top:var(--space-1);color:{{studentInfo.failCount > 0 ? 'var(--color-danger)' : 'var(--color-success)'}}">{{studentInfo.failCount}}</text>
      <text class="text-xs text-muted" style="margin-top:2px">{{failStatusText}}</text>
    </view>
  </view>

  <!-- 学业预警 -->
  <view class="section-hd">
    <text class="section-title">学业预警</text>
  </view>
  <view class="card" wx:if="{{warnings.length}}">
    <view class="list-item tappable" wx:for="{{warnings}}" wx:key="id">
      <view class="dot" style="background:{{item.level === 3 ? 'var(--color-danger)' : item.level === 2 ? '#F97316' : 'var(--color-warning)'}}"></view>
      <view class="flex-1" style="margin-left:var(--space-3)">
        <text class="text-sm font-medium text-ellipsis">{{item.title}}</text>
        <text class="text-xs text-muted" style="display:block;margin-top:2px">{{item.description || item.reason || ''}}</text>
      </view>
      <text class="text-xs text-muted">{{item.time || item.createTime || ''}}</text>
    </view>
  </view>
  <view class="empty-state" wx:else>
    <text class="empty-state-text" style="color:var(--color-success)">暂无预警，继续保持</text>
  </view>
</view>
