<view class="page ld-page">
  <!-- 公式说明 -->
  <view class="card" style="padding:var(--space-4);margin-bottom:var(--space-4)">
    <text class="text-md font-semibold" style="display:block;margin-bottom:var(--space-3)">等级计算规则</text>
    <text class="text-sm text-muted" style="line-height:1.8">
      综合得分 S = 学分进度 × 0.6 + 绩点进度 × 0.4
    </text>
    <text class="text-sm" style="display:block;margin-top:var(--space-2);color:var(--color-primary-dark);font-weight:var(--font-weight-semibold)">
      当前：S = {{creditRaw}} × 0.6 + {{gpaRaw}} × 0.4 = {{score}}
    </text>
  </view>

  <!-- 等级列表 -->
  <text class="text-md font-semibold" style="display:block;margin-bottom:var(--space-3)">全部等级称号</text>

  <view wx:if="{{loading}}" class="text-center" style="padding:40px 0">
    <text class="text-sm text-muted">加载中…</text>
  </view>

  <view wx:else class="flex-col gap-3">
    <view class="ld-card {{item.level === currentLevel ? 'ld-active' : ''}}" wx:for="{{levelList}}" wx:key="level">
      <view class="ld-badge">LV.{{item.level}}</view>
      <view class="flex-1">
        <text class="text-base font-semibold">{{item.title}}</text>
        <text class="text-xs text-muted" style="display:block;margin-top:2px">S ∈ [{{item.minText}}, {{item.maxText}})</text>
      </view>
      <view wx:if="{{item.level === currentLevel}}" class="flex gap-1" style="align-items:center">
        <view class="dot" style="background:var(--color-primary-dark)"></view>
        <text class="text-xs font-semibold" style="color:var(--color-primary-dark)">当前</text>
      </view>
      <text wx:elif="{{item.level < currentLevel}}" class="text-md" style="color:var(--color-success)">✓</text>
    </view>
  </view>
</view>
