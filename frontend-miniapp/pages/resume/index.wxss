.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Card base */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* Resume header */
.resume-header {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.resume-title {
  font-size: 40rpx;
  font-weight: 700;
}
.score-box {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.stars {
  display: flex;
  gap: 6rpx;
  margin-bottom: 6rpx;
}
.star {
  width: 28rpx;
  height: 28rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}
.star.active {
  background-color: #FFD700;
}
.score-text {
  font-size: 24rpx;
  opacity: 0.9;
}
.header-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.meta-item {
  font-size: 26rpx;
  opacity: 0.9;
}

/* Section title with left accent bar */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.title-bar {
  width: 6rpx;
  height: 32rpx;
  background-color: #4A90D9;
  border-radius: 3rpx;
  margin-right: 14rpx;
}
.section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* Info rows */
.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #888;
  width: 100rpx;
  flex-shrink: 0;
}
.info-value {
  font-size: 28rpx;
  color: #333;
}

/* Education */
.edu-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.edu-item:last-child {
  border-bottom: none;
}
.edu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.edu-school {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.edu-period {
  font-size: 24rpx;
  color: #999;
}
.edu-major {
  font-size: 26rpx;
  color: #666;
}

/* Internship */
.intern-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.intern-item:last-child {
  border-bottom: none;
}
.intern-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.intern-role {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.intern-period {
  font-size: 24rpx;
  color: #999;
}
.intern-company {
  font-size: 26rpx;
  color: #4A90D9;
  margin-bottom: 6rpx;
}
.intern-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

/* Skills */
.skills-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.skill-tag {
  font-size: 24rpx;
  color: #4A90D9;
  background-color: #EBF3FC;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

/* Self intro */
.self-intro {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* AI optimize button */
.btn-ai {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 90rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 45rpx;
  margin: 40rpx 0 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}
.btn-ai text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
