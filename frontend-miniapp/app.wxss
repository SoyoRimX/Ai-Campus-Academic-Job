/*
 * ============================================================
 *  ACAJ 微信小程序 — 全局设计系统
 *  Professional + Approachable + Smart
 *  Primary: #9DB4C0 (salt-blue) · 与 Admin 端 tokens.css 同源
 * ============================================================
 */

page {
  /* ---- Palette ---- */
  --color-primary: #9DB4C0;
  --color-primary-dark: #7A9BAE;
  --color-primary-light: #C9D6DF;
  --color-primary-bg: #ECF3F6;

  --color-bg: #F8F9FA;
  --color-surface: #FFFFFF;
  --color-border: #E8ECF1;
  --color-border-light: #F1F3F6;

  --color-text: #1E293B;
  --color-text-secondary: #64748B;
  --color-text-muted: #94A3B8;

  --color-success: #22C55E;
  --color-success-bg: #F0FDF4;
  --color-warning: #F59E0B;
  --color-warning-bg: #FFFBEB;
  --color-danger: #EF4444;
  --color-danger-bg: #FEF2F2;

  /* ---- Spacing ---- */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;

  /* ---- Typography ---- */
  --font-xs: 12px;
  --font-sm: 13px;
  --font-base: 14px;
  --font-md: 16px;
  --font-lg: 18px;
  --font-xl: 20px;
  --font-2xl: 24px;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --line-height: 1.5;

  /* ---- Radius ---- */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --radius-xl: 20px;
  --radius-full: 9999px;

  /* ---- Shadows ---- */
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 2px 10px rgba(0,0,0,0.05);
  --shadow-lg: 0 4px 16px rgba(0,0,0,0.08);

  /* ---- Transitions ---- */
  --ease-out: cubic-bezier(0.4, 0, 0.2, 1);
  --duration-fast: 120ms;
  --duration-normal: 200ms;

  /* ---- Layout ---- */
  --tab-bar-height: 50px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);

  /* ---- Apply defaults ---- */
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
  font-size: var(--font-base);
  line-height: var(--line-height);
  color: var(--color-text);
  background-color: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

/* ============================================================
   Utility classes
   ============================================================ */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; min-width: 0; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }

.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-base { font-size: var(--font-base); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-muted { color: var(--color-text-secondary); }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-center { text-align: center; }
.font-medium { font-weight: var(--font-weight-medium); }
.font-semibold { font-weight: var(--font-weight-semibold); }
.font-bold { font-weight: var(--font-weight-bold); }

/* ============================================================
   Shared component classes (used across pages)
   ============================================================ */

/* Card */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* Section header */
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-4) var(--space-3);
}
.section-title {
  font-size: var(--font-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text);
}

/* List item */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border-light);
}
.list-item:last-child { border-bottom: none; }

/* Tag / Badge */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  font-weight: var(--font-weight-medium);
}
.tag-primary { background: var(--color-primary-bg); color: var(--color-primary-dark); }
.tag-success { background: var(--color-success-bg); color: var(--color-success); }
.tag-warning { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-danger { background: var(--color-danger-bg); color: var(--color-danger); }

/* Dot indicator */
.dot { width: 8px; height: 8px; border-radius: var(--radius-full); flex-shrink: 0; }
.dot-red { background: var(--color-danger); }
.dot-orange { background: #F97316; }
.dot-yellow { background: var(--color-warning); }
.dot-green { background: var(--color-success); }

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-8) var(--space-4);
}
.empty-state-icon {
  font-size: 48px;
  margin-bottom: var(--space-3);
  opacity: 0.4;
}
.empty-state-text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

/* Primary button */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  padding: 0 var(--space-6);
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #FFF;
  font-size: var(--font-md);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 4px 12px rgba(157, 180, 192, 0.35);
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; }

/* Secondary / outline button */
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  padding: 0 var(--space-6);
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  border: 2px solid var(--color-primary-light);
}
.btn-outline::after { border: none; }
.btn-outline:active { background: var(--color-primary-bg); }

/* Page container (padding + safe area) */
.page {
  min-height: 100vh;
  padding: var(--space-4);
  padding-bottom: calc(var(--tab-bar-height) + var(--safe-bottom) + var(--space-4));
}

/* Tap feedback */
.tappable:active { opacity: 0.7; transform: scale(0.98); transition: all var(--duration-fast) var(--ease-out); }
