/*
 * ============================================
 *  AI校园学业就业助手 — 全局样式
 *  wxss 盐系低饱和配色方案
 *  间距优先使用 px 单位
 * ============================================
 */

page {
  --color-primary: #9DB4C0;
  --color-secondary-light: #E0E5E9;
  --color-secondary-warm: #F2EFE9;
  --color-secondary-green: #C9D6DF;
  --color-bg: #F8F9FA;
  --color-text-primary: #666666;
  --color-text-secondary: #999999;
  --color-interactive: #B8C5D6;
  --color-disabled: #D1D5DB;
  --color-white: #FFFFFF;
  --color-shadow: rgba(0, 0, 0, 0.05);
  --radius-sm: 8px;
  --radius-md: 8px;
  --radius-lg: 8px;
  --radius-xl: 12px;
  --spacing-xs: 8px;
  --spacing-sm: 12px;
  --spacing-md: 16px;
  --spacing-lg: 20px;
  --spacing-xl: 24px;
  --font-xs: 12px;
  --font-sm: 13px;
  --font-base: 14px;
  --font-md: 16px;
  --font-lg: 18px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  font-size: var(--font-base);
  line-height: 1.5;
}

/* ========================================
   通用弹性布局
   ======================================== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* ========================================
   通用卡片样式
   ======================================== */
.card {
  background-color: var(--color-white);
  border-radius: var(--radius-md);
  box-shadow: 0 2px 10px var(--color-shadow);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.card-hover {
  transform: scale(1.02);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

/*
 * 毛玻璃兼容说明：
 * backdrop-filter 在 iOS 微信（基础库 ≥ 2.9.0）原生支持；
 * Android 部分机型不生效，此时半透明 rgba 背景作为降级方案。
 */
.frost-glass {
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(157, 180, 192, 0.12);
}

/* ========================================
   通用文字样式
   ======================================== */
.text-primary {
  color: var(--color-text-primary);
  font-size: var(--font-base);
}

.text-secondary {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-center {
  text-align: center;
}

/* ========================================
   通用标签
   ======================================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: var(--font-xs);
  white-space: nowrap;
}

.tag-blue {
  background-color: #ECF3F6;
  color: var(--color-primary);
}

.tag-green {
  background-color: #ECF2EB;
  color: #8AAA8B;
}

.tag-orange {
  background-color: #F7F1E8;
  color: #C4A882;
}

.tag-red {
  background-color: #F5ECEC;
  color: #C59B9B;
}

/* ========================================
   通用按钮
   ======================================== */
.btn-primary {
  background-color: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  padding: 10px 24px;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background-color: var(--color-interactive);
}

/* ========================================
   空状态
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

/* ========================================
   分隔线
   ======================================== */
.divider {
  height: 1px;
  background-color: var(--color-secondary-light);
  margin: var(--spacing-md) 0;
}

/* ========================================
   点击态复用类
   ======================================== */
.tappable {
  transition: opacity 0.2s ease;
}

.tappable:active {
  opacity: 0.8;
}
