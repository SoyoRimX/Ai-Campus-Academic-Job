# 数据库（生产环境必填）
DB_URL=jdbc:mysql://localhost:3306/acaj?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=root
DB_PASSWORD=

# Redis（生产环境必填）
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 密钥（生产环境必须修改为强随机字符串）
# 生成方法: openssl rand -base64 64
JWT_SECRET=change-me-use-a-strong-random-string-at-least-256-bits
JWT_EXPIRATION=86400000

# AI 平台（金蝶苍穹 AI）
AI_BASE_URL=https://ai.kingdee.com/api
AI_API_KEY=your-api-key-here
AI_MODEL=default
